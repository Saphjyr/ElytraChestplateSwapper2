{
	"schemaVersion": 1,
	"id": "elytra-chestplate-swapper",
	"version": "${version}",
	"name": "Elytra Chestplate Swapper",
	"description": "A simple quality of life mod that swaps between chestplate and elytra on a keystroke.",
	"authors": [
		"Saphjyr"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/elytra-chestplate-swapper/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"saphjyr.ecs.ElytraChestplateSwapper"
		],
		"client": [
			"saphjyr.ecs.ElytraChestplateSwapperClient"
		]
	},
	"mixins": [
		"elytra-chestplate-swapper.mixins.json",
		{
			"config": "elytra-chestplate-swapper.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.5",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}